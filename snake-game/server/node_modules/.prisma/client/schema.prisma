// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Score {
  id         Int      @id @default(autoincrement())
  playerName String
  score      Int
  level      Int
  createdAt  DateTime @default(now())

  @@index([score(sort: Desc)])
  @@index([playerName])
}
